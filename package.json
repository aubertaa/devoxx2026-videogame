{
  "name": "craft-runner-devoxx2026",
  "description": "Craft Runner - An endless runner game about collecting software craftsmanship patterns. Devoxx France 2026 Edition.",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aubertaa/devoxx2026-videogame.git"
  },
  "author": "Devoxx France 2026",
